---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('news');
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const categories = ["Ciber-Contingencia", "Noticias", "Comparativas"];
const base = "/OpenCyberNews";
---

<Layout title="OpenCyberNews // Security Intelligence Feed">
	<header class="mb-16 border-l-2 border-cyber-red pl-6">
		<div class="flex items-center gap-2.5 mb-2">
			<span class="status-dot status-dot-green"></span>
			<span class="text-[0.65rem] text-cyber-muted tracking-wider">ESTADO: SISTEMA_ACTIVO // SECTOR: PUBLICO</span>
		</div>
		<h1 class="text-5xl font-bold m-0 tracking-tight text-white">
			INTEL_<span class="text-cyber-red text-glow-red">FEED</span>
		</h1>
		<p class="text-cyber-dim text-sm mt-2">[+] Monitoreando amenazas y comparativas técnicas...</p>
	</header>

	<div>
		{categories.map(cat => {
			const categoryPosts = posts.filter(p => p.data.category === cat);
			if (categoryPosts.length === 0) return null;

			const isUrgent = cat === 'Ciber-Contingencia';
			const isCyan = cat === 'Comparativas';

			return (
				<section class="mb-16">
					<div class="flex items-baseline gap-4 mb-6 border-b border-cyber-border">
						<h2 class={`text-base m-0 pb-2 font-bold ${isUrgent ? 'text-cyber-red animate-blink' : isCyan ? 'text-cyber-cyan' : 'text-white'}`}>
							// {cat.toUpperCase()}
						</h2>
						<span class="text-[0.6rem] text-cyber-muted">{categoryPosts.length} OBJ(S)</span>
					</div>
					
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
						{categoryPosts.map(post => (
							<article class={`bg-cyber-card border border-cyber-border transition-all duration-300 hover:border-cyber-red hover:bg-cyber-card-hover hover:-translate-y-1 group ${isUrgent ? 'border-l-[3px] border-l-cyber-red' : ''}`}>
								<a href={`${base}/news/${post.slug}`} class="block p-6">
									<div class="flex justify-between text-[0.65rem] text-cyber-dim mb-4">
										<span>{post.data.pubDate.toLocaleDateString()}</span>
										<span>REF: {post.slug.split('/').pop()?.toUpperCase()}</span>
									</div>
									<h3 class="text-white font-bold text-lg m-0 mb-3 leading-snug group-hover:text-cyber-red transition-colors">{post.data.title}</h3>
									<p class="text-sm text-cyber-dim leading-relaxed mb-6">{post.data.description}</p>
									<div class="text-xs text-cyber-red font-bold opacity-0 transition-opacity duration-300 group-hover:opacity-100">
										<span>&gt;</span> ACCEDER_AL_REPORTE_
									</div>
								</a>
							</article>
						))}
					</div>
				</section>
			);
		})}
	</div>
</Layout>
