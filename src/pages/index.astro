---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('news');
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Lista actualizada de categorías
const categories = ["Ciber-Contingencia", "Noticias", "Comparativas"];
---

<Layout title="OpenCyberNews // Security Feed">
	<header class="hero">
		<h1>INTEL_FEED: <span class="typing">SISTEMA_ACTIVO</span></h1>
		<p class="status">[+] Monitoreando vulnerabilidades en tiempo real...</p>
	</header>

	{categories.map(cat => {
		const categoryPosts = posts.filter(p => p.data.category === cat);
		if (categoryPosts.length === 0) return null;

		return (
			<section class="category-block">
				<div class="category-header">
					<h2 class={cat === 'Ciber-Contingencia' ? 'blink' : ''}>// {cat}</h2>
					<span class="count">{categoryPosts.length} ARCHIVOS</span>
				</div>
				
				<div class="news-grid">
					{categoryPosts.map(post => (
						<article class={`news-card ${cat === 'Ciber-Contingencia' ? 'urgent-card' : ''}`}>
                            <a href={`/OpenCyberNews/news/${post.slug}`}>
								<div class="card-tag">{post.data.category}</div>
								<time>{post.data.pubDate.toLocaleDateString()}</time>
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
								<div class="card-footer">
									<span class="arrow">></span> LEER_REPORTE_
								</div>
							</a>
						</article>
					))}
				</div>
			</section>
		);
	})}
</Layout>

<style>
    /* ... (El CSS que ya tenías antes) ... */
    .urgent-card { border-left: 4px solid var(--pure-red); box-shadow: inset 5px 0 15px rgba(255, 0, 0, 0.1); }
    .blink { animation: blinker 1.5s linear infinite; color: var(--pure-red); text-shadow: 0 0 10px var(--pure-red); }
</style>
