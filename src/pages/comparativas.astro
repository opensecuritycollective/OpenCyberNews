---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('news');
const posts = allPosts
	.filter(p => p.data.category === 'Comparativas')
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const base = "/OpenCyberNews";
---

<Layout title="Comparativas // OpenCyberNews">
	<header class="mb-12 pb-8 border-b border-cyber-border">
		<!-- Breadcrumb -->
		<div class="text-xs text-cyber-muted mb-6 flex items-center gap-2">
			<a href={`${base}/`} class="text-cyber-dim hover:text-cyber-cyan transition-colors">INICIO</a>
			<span class="text-cyber-dark">/</span>
			<span class="text-cyber-cyan">COMPARATIVAS</span>
		</div>
		
		<!-- Title block -->
		<div class="flex items-start gap-4 mb-4">
			<div class="w-1 h-16 flex-shrink-0 mt-2" style="background: linear-gradient(180deg, #00ffff 0%, transparent 100%);"></div>
			<div>
				<h1 class="text-4xl font-bold text-white tracking-tight m-0">// COMPARATIVAS</h1>
				<p class="text-xs text-cyber-cyan mt-1">[{posts.length}] análisis técnicos disponibles</p>
			</div>
		</div>
		
		<p class="text-cyber-dim text-sm max-w-xl leading-relaxed">
			Análisis detallados y comparaciones técnicas entre herramientas, frameworks,
			estándares y metodologías de seguridad. Guías para tomar decisiones informadas.
		</p>
	</header>

	{posts.length > 0 ? (
		<div class="flex flex-col gap-4">
			{posts.map((post, index) => (
				<article class="bg-cyber-card border border-cyber-border opacity-0 animate-fade-in-up hover:border-cyber-cyan hover:bg-[#0c0c0c] transition-all duration-300 group" 
						 style={`animation-delay: ${index * 0.1}s; animation-fill-mode: forwards;`}>
					<a href={`${base}/news/${post.slug}`} class="flex p-6 gap-6 items-start">
						<!-- Icon -->
						<div class="w-12 h-12 border border-cyber-border flex items-center justify-center flex-shrink-0 text-cyber-dark transition-all duration-300 group-hover:border-cyber-cyan group-hover:text-cyber-cyan group-hover:shadow-glow-cyan">
							<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
							</svg>
						</div>
						
						<!-- Content -->
						<div class="flex-1">
							<div class="flex justify-between items-center mb-3 text-xs">
								<span class="text-cyber-cyan font-bold">ANÁLISIS #{String(index + 1).padStart(3, '0')}</span>
								<span class="text-cyber-muted uppercase">{post.data.pubDate.toLocaleDateString('es-ES', { 
									year: 'numeric', 
									month: 'short', 
									day: 'numeric' 
								})}</span>
							</div>
							<h2 class="text-xl font-bold text-white mb-2 leading-snug group-hover:text-cyber-cyan transition-colors">{post.data.title}</h2>
							<p class="text-sm text-cyber-dim leading-relaxed mb-4">{post.data.description}</p>
							<div class="flex justify-between items-center">
								<!-- Progress bar -->
								<div class="w-24 h-0.5 bg-cyber-border rounded overflow-hidden">
									<span class="block h-full bg-gradient-to-r from-cyber-cyan to-blue-500 scale-x-0 origin-left transition-transform duration-500 group-hover:scale-x-100"></span>
								</div>
								<span class="text-cyber-cyan text-xs font-bold opacity-0 transition-opacity duration-300 group-hover:opacity-100">
									EXPLORAR_ANÁLISIS <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">→</span>
								</span>
							</div>
						</div>
					</a>
				</article>
			))}
		</div>
	) : (
		<div class="text-center py-20 border border-dashed border-cyber-border bg-cyber-card">
			<div class="w-16 h-16 mx-auto mb-6 text-[#222]">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-full h-full">
					<path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
				</svg>
			</div>
			<h2 class="text-cyber-muted text-xl font-bold mb-2">SIN_COMPARATIVAS</h2>
			<p class="text-cyber-dark text-sm mb-8">No hay análisis comparativos registrados actualmente.</p>
			<a href={`${base}/`} class="text-cyber-cyan text-sm font-bold hover:text-glow-cyan transition-all">&lt; VOLVER_AL_INICIO</a>
		</div>
	)}
</Layout>
