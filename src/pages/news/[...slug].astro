---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const base = "/OpenCyberNews";

export async function getStaticPaths() {
  const newsEntries = await getCollection('news');
  return newsEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'news'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} // OpenCyberNews`}>
  <article class="max-w-3xl mx-auto bg-white/5 p-8 md:p-12 border border-cyber-border">
    <header class="mb-8">
      <div class="text-xs text-cyber-red mb-4 flex items-center gap-2.5">
        <span class="w-2 h-2 bg-cyber-red shadow-glow-red"></span>
        ID: {entry.slug.toUpperCase()} // CLASIFICACIÓN: {entry.data.category.toUpperCase()}
      </div>
      <time class="text-xs text-cyber-muted block mb-2">{entry.data.pubDate.toLocaleDateString('es-ES', { 
        year: 'numeric', 
        month: 'long', 
        day: 'numeric' 
      })}</time>
      <h1 class="text-3xl md:text-4xl font-bold text-white leading-tight my-2">{entry.data.title}</h1>
      <p class="text-lg text-cyber-dim border-l-2 border-cyber-muted pl-4 mt-6">{entry.data.description}</p>
    </header>

    <hr class="border-0 border-t border-cyber-border my-12" />

    <div class="markdown-content leading-relaxed text-gray-300">
      <Content />
    </div>

    <footer class="mt-16 pt-8 border-t border-cyber-border">
      <a href={`${base}/`} class="text-cyber-red font-bold text-sm hover:text-glow-red transition-all">
        &lt; VOLVER_AL_FEED
      </a>
    </footer>
  </article>
</Layout>

<style is:global>
  .markdown-content h2 {
    @apply text-cyber-red mt-8 mb-4 pb-2 border-b border-cyber-border text-xl font-bold;
  }

  .markdown-content h3 {
    @apply text-white mt-6 mb-3 text-lg font-bold;
  }

  .markdown-content p {
    @apply mb-6;
  }

  .markdown-content code {
    @apply bg-cyber-border px-1.5 py-0.5 text-cyber-red text-sm;
  }

  .markdown-content pre {
    @apply bg-cyber-card p-4 overflow-x-auto my-6 border border-cyber-border;
  }

  .markdown-content pre code {
    @apply bg-transparent p-0;
  }

  .markdown-content ul, .markdown-content ol {
    @apply ml-6 mb-6;
  }

  .markdown-content li {
    @apply mb-2;
  }

  .markdown-content ul li::marker {
    @apply text-cyber-red;
  }

  .markdown-content a {
    @apply text-cyber-red underline;
  }

  .markdown-content a:hover {
    text-shadow: 0 0 15px rgba(255, 0, 0, 0.3);
  }

  .markdown-content blockquote {
    @apply border-l-4 border-cyber-red pl-4 my-6 text-cyber-dim italic;
  }

  .markdown-content table {
    @apply w-full border-collapse my-6;
  }

  .markdown-content th, .markdown-content td {
    @apply border border-cyber-border px-4 py-2 text-left;
  }

  .markdown-content th {
    @apply bg-cyber-card text-cyber-red;
  }
</style>
