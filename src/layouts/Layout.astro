---
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<header class="main-header">
			<div class="nav-container">
				<a href="/" class="logo">
					<span class="dot"></span> OPEN_CYBER_<span class="red-text">NEWS</span>
				</a>
				<nav>
					<a href="/noticias">NOTICIAS</a>
					<a href="/comparativas">COMPARATIVAS</a>
					<a href="/urgente" class="urgent-link">URGENTE</a>
				</nav>
			</div>
		</header>
		<div class="scanline"></div>
		<main class="content-wrapper">
			<slot />
		</main>
		<footer class="main-footer">
			<p>&copy; {new Date().getFullYear()} Open Security Collective // Terminal_ID: {Math.random().toString(36).substr(2, 9)}</p>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--bg-black: #080808;
		--card-bg: #111111;
		--pure-red: #ff4d4d;
		--dim-red: #8b0000;
		--text-white: #e0e0e0;
		--text-dim: #888888;
		--border: #222222;
	}

	* { box-sizing: border-box; }

	body {
		background-color: var(--bg-black);
		color: var(--text-white);
		font-family: 'JetBrains Mono', monospace;
		margin: 0;
		line-height: 1.6;
		background-image: radial-gradient(#1a1a1a 1px, transparent 1px);
		background-size: 30px 30px;
	}

	.main-header {
		border-bottom: 1px solid var(--border);
		padding: 1.5rem 0;
		background: rgba(8, 8, 8, 0.9);
		backdrop-filter: blur(10px);
		position: sticky;
		top: 0;
		z-index: 100;
	}

	.nav-container {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 2rem;
	}

	.logo {
		font-weight: 700;
		font-size: 1.2rem;
		text-decoration: none;
		color: var(--text-white);
		letter-spacing: -1px;
	}

	.logo .dot {
		display: inline-block;
		width: 8px;
		height: 8px;
		background: var(--pure-red);
		margin-right: 5px;
		box-shadow: 0 0 10px var(--pure-red);
	}

	.red-text { color: var(--pure-red); }

	nav a {
		text-decoration: none;
		color: var(--text-dim);
		font-size: 0.8rem;
		margin-left: 1.5rem;
		transition: all 0.3s ease;
	}

	nav a:hover { color: var(--pure-red); }

	.urgent-link {
		border: 1px solid var(--pure-red);
		padding: 5px 12px;
		color: var(--pure-red) !important;
	}

	.urgent-link:hover {
		background: var(--pure-red);
		color: black !important;
		box-shadow: 0 0 15px var(--pure-red);
	}

	.content-wrapper {
		max-width: 1200px;
		margin: 3rem auto;
		padding: 0 2rem;
		min-height: 80vh;
	}

	.main-footer {
		text-align: center;
		padding: 4rem 2rem;
		color: var(--text-dim);
		font-size: 0.7rem;
		border-top: 1px solid var(--border);
	}

	/* Efecto de línea de escaneo retro */
	.scanline {
		width: 100%;
		height: 2px;
		background: rgba(255, 77, 77, 0.05);
		position: fixed;
		top: 0;
		z-index: 999;
		pointer-events: none;
		animation: scan 8s linear infinite;
	}

	@keyframes scan {
		0% { top: 0; }
		100% { top: 100%; }
	}
</style>
