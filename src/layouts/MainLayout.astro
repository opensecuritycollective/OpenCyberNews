---
import Header from '../components/layout/Header.astro'
const base = "/OpenCyberNews";
---

<div
  class="bg-stone-950 text-white font-mono leading-relaxed bg-cyber-dots bg-dots
    min-h-screen flex flex-col"
>
  <div
    class="w-full h-24 z-40 fixed top-0 pointer-events-none animate-scan"
    style="background: linear-gradient(0deg, transparent 0%, rgba(255,0,0,0.02) 50%, transparent 100%);"
  >
  </div>

  <Header />

  <main class="flex-1 max-w-6xl mx-auto my-8 px-8">
    <slot />
  </main>

  <footer
    class="text-center py-12 text-stone-500 text-[0.8rem] border-t border-cyber-border"
  >
    <p>
      &copy; {new Date().getFullYear()} Open Security Collective // Terminal_ID:
      {Math.random().toString(36).substr(2, 9)}
    </p>
  </footer>
</div>
